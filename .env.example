# Variables de entorno — EcoAdmin
# Este archivo NUNCA debe commitearse (está en .gitignore)
# Copia este archivo como .env y rellena los valores reales

# Correo (para EmailService — Fase 5)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password

# JWT (si se implementa autenticación por token)
JWT_SECRET=cambia_esto_por_una_clave_segura_de_al_menos_32_caracteres
JWT_EXPIRATION_MS=86400000

# PostgreSQL (Dockploy / Producción)
DATABASE_URL=jdbc:postgresql://db:5432/ecoadmin
DATABASE_USER=ecoadmin
DATABASE_PASSWORD=cambia_esto
DB_NAME=ecoadmin

# Admin inicial
ADMIN_EMAIL=admin@ecoadmin.com
ADMIN_PASSWORD=cambia_esto

# Perfil de Spring
SPRING_PROFILES_ACTIVE=prod
